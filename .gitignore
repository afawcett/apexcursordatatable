# Salesforce DX Project .gitignore

# Salesforce CLI
.sf/
.sfdx/

# Scratch org files
*.org
*.scratchorg

# OS generated files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Logs
*.log
debug.log

# Generated import data
data/*.csv

# Node deps for optional dev scripts (scripts/listen-adaptive-chunk-events.mjs)
scripts/node_modules/

# Temporary files
.tmp/
*.tmp
*.temp
*.bak